# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here  # For Gemini (Referee only)
MISTRAL_API_KEY=your_mistral_api_key_here  # For council
GROQ_API_KEY=your_groq_api_key_here  # For council (optional)

# Vector Database (Pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=indian-labour-law

# Embeddings (Cohere - FREE alternative to OpenAI)
# Get free API key from: https://dashboard.cohere.com/api-keys
# Free tier: 1000 embeds/month production, unlimited trial
COHERE_API_KEY=your_cohere_api_key_here
USE_COHERE_EMBEDDINGS=true  # Set to true to use free Cohere instead of OpenAI

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/legal_advisor
# For SQLite (development):
# DATABASE_URL=sqlite:///./legal_advisor.db

# LLM Model Configuration
OPENAI_MODEL=gpt-4-turbo-preview  # Council member
MISTRAL_MODEL=mistral-large-latest  # Council member
GROQ_MODELS=llama-3.3-70b-versatile,qwen2.5-32b-instruct  # Multiple Groq models (comma-separated)
GEMINI_MODEL=gemini-1.5-flash  # Referee only

# Council Settings
COUNCIL_CONSENSUS_THRESHOLD=0.6
LLM_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# Rate Limiting (to avoid 429 errors)
ENABLE_OPENAI=true  # OpenAI in council
ENABLE_MISTRAL=true  # Mistral in council
ENABLE_GROQ=false  # Groq in council (disable by default to reduce calls)
MAX_CONCURRENT_LLM_CALLS=3  # Lower to 1-2 if hitting rate limits
RETRY_DELAY_SECONDS=2
EXPONENTIAL_BACKOFF=true

# Authentication (generate secret: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Application
DEBUG=True
LOG_LEVEL=INFO

# Vector Database Upload Settings (to avoid rate limits)
VECTOR_UPLOAD_BATCH_SIZE=20  # Lower if still hitting limits
VECTOR_UPLOAD_DELAY=1.0  # Increase to 2-3 if needed

# Trello 
TRELLO_API_KEY=
TRELLO_SECRET_KEY=